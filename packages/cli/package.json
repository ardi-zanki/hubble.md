{
	"name": "@hubble.md/cli",
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"bin": {
		"hubble": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x dist/index.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@hubble.md/convex-client": "workspace:*",
		"@hubble.md/sync": "workspace:*",
		"@hubble.md/sync-backend": "workspace:*",
		"chokidar": "^4.0.3",
		"convex": "^1.34.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "~5.8.3"
	}
}

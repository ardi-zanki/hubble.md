---
import Base from "../layouts/Base.astro";
import Avatar from "../components/Avatar.astro";

const concepts = [
  { id: "a", name: "Deep Forest", note: "Subtle · forest green on cream · Fraunces serif", body: "#fff", ink: "#173d2e", gleam: "#f4c13c", bg: "#fbf7ec", fg: "#173d2e" },
  { id: "b", name: "Bold Banana", note: "Loud · banana yellow · giant Obviously display", body: "#173d2e", ink: "#0f2c20", gleam: "#f4c13c", bg: "#f4c13c", fg: "#173d2e" },
  { id: "c", name: "Stencil Deck", note: "Graphic · black + primary yellow · playing-card", body: "#fff", ink: "#0a0a0a", gleam: "#ffd400", bg: "#ffd400", fg: "#0a0a0a" },
];
---
<Base title="Hubble — concept gallery">
  <main>
    <header>
      <div class="wordmark" style="width:160px;height:40px;color:#0a0a0a"></div>
      <p>Landing page concept gallery</p>
    </header>
    <div class="grid">
      {concepts.map((c) => (
        <a class="card" href={`/${c.id}`} style={`--bg:${c.bg};--fg:${c.fg}`}>
          <div class="av"><Avatar size={64} body={c.body} ink={c.ink} gleam={c.gleam} /></div>
          <h2>{c.name}</h2>
          <p>{c.note}</p>
          <span class="go">Open concept {c.id.toUpperCase()} →</span>
        </a>
      ))}
    </div>
  </main>

  <style>
    main { min-height: 100vh; background: #f3f1ea; padding: clamp(2rem, 6vw, 5rem); font-family: var(--font-body); }
    header { display: flex; align-items: center; gap: 1rem; margin-block-end: 3rem; }
    header p { color: #6b6f6a; font-size: 0.95rem; }
    .grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); max-width: 1100px; }
    .card { background: var(--bg); color: var(--fg); border-radius: 24px; padding: 2rem; text-decoration: none; border: 2px solid rgba(0,0,0,0.08); transition: transform .15s ease, box-shadow .15s ease; display: flex; flex-direction: column; gap: .5rem; min-height: 280px; }
    .card:hover { transform: translateY(-4px) rotate(-1deg); box-shadow: 0 18px 40px rgba(0,0,0,.16); }
    .av { margin-block-end: auto; }
    .card h2 { font-family: var(--font-rounded); font-weight: 600; font-size: 1.6rem; }
    .card p { opacity: .8; font-size: .9rem; }
    .go { font-family: var(--font-rounded); font-weight: 600; margin-block-start: 1rem; }
  </style>
</Base>

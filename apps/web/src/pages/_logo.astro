---
import Base from "../layouts/Base.astro";

// shared bits
const RIGHT = "M40.2026 47.0052L38.8342 47.2636C33.8143 48.2115 28.9764 44.9104 28.0285 39.8905L23.5926 16.3984C22.6449 11.3786 25.9458 6.54062 30.9657 5.59275L32.3341 5.33436C39.5246 3.9766 46.4545 8.70527 47.8125 15.8958L50.764 31.5268C52.1218 38.7175 47.3933 45.6474 40.2026 47.0052Z";
const LEFT = "M11.9097 8.99L12.5921 8.85163C19.0583 7.54056 25.363 11.7196 26.6741 18.1858L30.4145 36.6336C31.7253 43.0997 27.5464 49.4045 21.0804 50.7156L20.398 50.854C14.3088 52.0886 8.37162 48.1529 7.13679 42.0638L3.11962 22.2512C1.88496 16.1619 5.82043 10.2246 11.9097 8.99Z";
// 4-point sparkle in a 24x24 box, center 12,12
const SPK = "M12 0C13 8 16 11 24 12C16 13 13 16 12 24C11 16 8 13 0 12C8 11 11 8 12 0Z";
const FG = "#173d2e", CREAM = "#fff8e7", GOLD = "#ffc21f", WHITE = "#fff";

const sparkle = (x, y, s, fill) =>
  `<path transform="translate(${x - 12 * s} ${y - 12 * s}) scale(${s})" d="${SPK}" fill="${fill}"/>`;

const marks = [
  {
    id: "twinkle",
    name: "Twinkle Eye",
    desc: "Closest to today's mark — keeps the body, but the eye's glint becomes a sparkle, with a star nearby. Minimal evolution.",
    svg: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(4 3.5)">
        <path d="${RIGHT}" fill="${CREAM}" stroke="${FG}" stroke-width="2"/>
        <path d="${LEFT}" fill="${CREAM}" stroke="${FG}" stroke-width="2"/>
        <circle cx="31.4" cy="27.4" r="12.75" fill="${FG}"/>
        ${sparkle(34.4, 24.4, 0.42, WHITE)}
      </g>
      ${sparkle(52, 12, 0.42, GOLD)}
    </svg>`,
  },
  {
    id: "stargazer",
    name: "Stargazer",
    desc: "The character looks up at a star — gives it personality and a clear telescope intent (gazing at the sky).",
    svg: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(4 3.5)">
        <path d="${RIGHT}" fill="${CREAM}" stroke="${FG}" stroke-width="2"/>
        <path d="${LEFT}" fill="${CREAM}" stroke="${FG}" stroke-width="2"/>
        <circle cx="34.5" cy="22.5" r="11.5" fill="${FG}"/>
        <circle cx="38" cy="19" r="3" fill="${WHITE}"/>
      </g>
      ${sparkle(54, 12, 0.5, GOLD)}
      ${sparkle(45, 6, 0.28, GOLD)}
    </svg>`,
  },
  {
    id: "saturn",
    name: "Saturn Eye",
    desc: "Eye as a ringed planet. The orbit ring breaks the 'security-camera' read and signals space — works without the body.",
    svg: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="32" cy="33" rx="27" ry="9.5" fill="none" stroke="${FG}" stroke-width="3" transform="rotate(-20 32 33)"/>
      <circle cx="32" cy="32" r="15.5" fill="${CREAM}" stroke="${FG}" stroke-width="3"/>
      <circle cx="32" cy="32" r="8" fill="${FG}"/>
      <circle cx="35" cy="29" r="3.2" fill="${WHITE}"/>
      <path d="M32 16.5 a 15.5 15.5 0 0 1 0 31" fill="none"/>
      ${sparkle(54, 11, 0.34, GOLD)}
    </svg>`,
  },
  {
    id: "telescope",
    name: "Telescope",
    desc: "A literal little telescope on a tripod — the lens is the Hubble eye, pointed at a star. Most explicit nod to the name.",
    svg: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" stroke-linecap="round" stroke-linejoin="round">
      <!-- legs -->
      <path d="M30 34 L21 53 M30 34 L33 55 M30 34 L41 50" stroke="${FG}" stroke-width="3" fill="none"/>
      <!-- tube -->
      <line x1="19" y1="41" x2="45" y2="18" stroke="${FG}" stroke-width="14"/>
      <line x1="19" y1="41" x2="45" y2="18" stroke="${CREAM}" stroke-width="9"/>
      <!-- eyepiece -->
      <circle cx="18" cy="42" r="3.4" fill="${FG}"/>
      <!-- lens = eye -->
      <circle cx="45.5" cy="17.5" r="8.5" fill="${FG}"/>
      <circle cx="45.5" cy="17.5" r="4" fill="${GOLD}"/>
      <circle cx="47.5" cy="15.5" r="1.6" fill="${WHITE}"/>
      ${sparkle(56, 9, 0.3, GOLD)}
    </svg>`,
  },
  {
    id: "spyglass",
    name: "Spyglass",
    desc: "A playful handheld telescope, tilted up. Hand-drawn energy; the lens carries a golden glint.",
    svg: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <g transform="rotate(-26 32 32)" stroke="${FG}" stroke-width="2" stroke-linejoin="round">
        <rect x="9" y="27" width="12" height="10" rx="3" fill="${CREAM}"/>
        <rect x="19" y="24.5" width="20" height="15" rx="4" fill="${CREAM}"/>
        <path d="M38 23 L52 18 L52 46 L38 41 Z" fill="${CREAM}"/>
        <ellipse cx="52" cy="32" rx="3.2" ry="13.5" fill="${GOLD}"/>
      </g>
      ${sparkle(13, 13, 0.34, GOLD)}
    </svg>`,
  },
];
---
<Base title="Hubble — logo riffs">
  <main>
    <header>
      <h1>Brand mark riffs</h1>
      <p>Telescope-themed directions for Hubble. Each shown large, as a standalone app icon (the case that read “security camera”), and tiny in a nav lockup.</p>
    </header>

    <div class="grid">
      {marks.map((m) => (
        <article class="card">
          <div class="big" set:html={m.svg} />
          <div class="meta">
            <h2>{m.name}</h2>
            <p>{m.desc}</p>
          </div>
          <div class="tests">
            <div class="tile" title="App icon"><div class="ico" set:html={m.svg} /></div>
            <div class="navlock">
              <div class="nv" set:html={m.svg} />
              <span class="wordmark" style="width:84px;height:21px;color:#173d2e"></span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>

  <style>
    main { background:#fbf7ec; color:#173d2e; min-height:100vh; padding:clamp(2rem,5vw,4rem);
      background-image:radial-gradient(circle at 1px 1px, rgba(23,61,46,.06) 1px, transparent 0); background-size:26px 26px; font-family:var(--font-body); }
    header { max-width:760px; margin-block-end:3rem; }
    header h1 { font-family:var(--font-rounded); font-weight:600; font-size:2rem; }
    header p { opacity:.75; margin-block-start:.5rem; }
    .grid { display:grid; gap:1.5rem; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); max-width:1200px; }
    .card { background:#fff; border:1.5px solid rgba(23,61,46,.16); border-radius:22px; padding:1.6rem; box-shadow:0 10px 30px rgba(23,61,46,.06); display:flex; flex-direction:column; gap:1.2rem; }
    .big { width:120px; height:120px; margin-inline:auto; }
    .big :global(svg) { width:100%; height:100%; }
    .meta h2 { font-family:var(--font-rounded); font-weight:600; font-size:1.3rem; }
    .meta p { opacity:.78; font-size:.92rem; margin-block-start:.3rem; }
    .tests { display:flex; align-items:center; gap:1.2rem; border-block-start:1.5px solid rgba(23,61,46,.12); padding-block-start:1.2rem; }
    .tile { width:64px; height:64px; border-radius:15px; background:#fff8e7; box-shadow:0 4px 14px rgba(23,61,46,.18), inset 0 0 0 1.5px rgba(23,61,46,.1); display:grid; place-items:center; flex:none; }
    .ico { width:46px; height:46px; }
    .ico :global(svg) { width:100%; height:100%; }
    .navlock { display:flex; align-items:center; gap:.5rem; }
    .nv { width:26px; height:26px; flex:none; }
    .nv :global(svg) { width:100%; height:100%; }
  </style>
</Base>
